{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "meridian-july",
  "workers_dev": true,
  "compatibility_date": "2026-06-12",
  "main": "./dist/_worker.js",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "vars": {
    "VITE_API_URL": "https://meridian-api.isaactrinidadllc.workers.dev"
  }
}
