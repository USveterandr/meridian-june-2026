{
  "name": "meridian-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init:local": "wrangler d1 execute meridian-db --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute meridian-db --remote --file=./schema.sql",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/test/api.test.ts src/test/everylisting.test.ts src/test/supercasas.test.ts src/test/markets.test.ts",
    "scrape:dry-run": "tsx scripts/scrape-dry-run.ts"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.100.0"
  }
}
